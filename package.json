{
  "name": "agency-incoming-api",
  "version": "1.0.0",
  "description": "Freede Agency Incoming API Spec",
  "main": "index.js",
  "repository": "https://github.com/Freede/agency-incoming-api.git",
  "author": "Freede <tech@freede.co>",
  "license": "MIT",
  "dependencies": {
    "speccy": "^0.11.0",
    "widdershins": "^4.0.1"
  },
  "scripts": {
    "combine": "speccy resolve ./reference/Agency-Incoming-API.v1.yaml -o Agency-Incoming-API.v1.yaml",
    "buildspec": "npx widdershins Agency-Incoming-API.v1.yaml --outfile ./source/index.html.md --user_templates ./source/templates",
    "serve": "docker run --rm --name slate -p 4567:4567 -v $(pwd)/source:/srv/slate/source slatedocs/slate serve",
    "build": "docker run --rm --name slate -v $(pwd)/docs:/srv/slate/build -v $(pwd)/source:/srv/slate/source slatedocs/slate",
    "buildall": "yarn combine && yarn buildspec && yarn build"
  }
}
